{
  "semi": true,
  "trailingComma": "es5",
  "singleQuote": true,
  "quoteProps": "as-needed",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "useTabs": false,
  "jsxSingleQuote": true,
  "jsxBracketSameLine": false,
  "requirePragma": false,
  "insertPragma": false,
  "proseWrap": "always",
  "printWidth": 100
}
